# ============================================================
# LLM provider keys
# ============================================================

# OpenRouter — primary router for OpenAI + Anthropic models (required)
# https://openrouter.ai/keys
OPEN_ROUTER_KEY=your_openrouter_key_here

# Groq — used directly for the Retriever agent (Llama 3.3 70B, sub-second latency)
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Google AI Studio — fallback model provider (Gemini)
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_key_here

# ============================================================
# Retrieval providers
# ============================================================

# Tavily — primary AI-optimized web search (recommended)
# https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Perplexity — fallback web search when Tavily is unavailable
# https://www.perplexity.ai/
PERPLEXITY_API_KEY=your_perplexity_key_here

# ============================================================
# Storage + Queue (required when running the FastAPI backend)
# ============================================================

# Neon Postgres — persistent storage for research_results
# https://neon.tech (free tier with 0.5 GB)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Upstash Redis — used for the ARQ job queue and SSE pub/sub channels
# https://upstash.com/ (free tier 10k commands/day)
# IMPORTANT: use the TCP/TLS endpoint (rediss://) not the REST URL
REDIS_URL=rediss://default:TOKEN@HOST:6379

# ============================================================
# Optional: per-agent model overrides (OpenRouter format)
# ============================================================
# RETRIEVER_MODEL=groq/llama-3.3-70b-versatile
# ANALYZER_MODEL=anthropic/claude-3-5-sonnet
# INSIGHT_MODEL=openai/gpt-4o
# REPORT_MODEL=anthropic/claude-3-5-haiku

# ============================================================
# Backend runtime
# ============================================================
# ENVIRONMENT=development
# PORT=8000
# Comma-separated list of CORS allowed origins. *.vercel.app preview
# origins are auto-allowed via regex in backend/main.py.
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# Frontend (Next.js) — set in frontend/.env.local, not here.
# NEXT_PUBLIC_API_URL=http://localhost:8000
# ============================================================
